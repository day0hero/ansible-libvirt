apiVersion: v1
metadata:
  name: {{ cluster_name }}
baseDomain: {{ cluster_domain }}

platform:
  none: {}

networking:
  networkType: OVNKubernetes
  machineNetwork:
    - cidr: {{ cluster_network.cidr }}
  clusterNetwork:
    - cidr: 10.128.0.0/14
      hostPrefix: 23
  serviceNetwork:
    - 172.30.0.0/16

compute:
  - name: worker
    replicas: {{ _worker_count }}

controlPlane:
  name: master
  replicas: {{ _master_count }}

pullSecret: '{{ _pull_secret_json }}'
sshKey: '{{ ssh_public_key }}'

additionalTrustBundle: |
{{ _quay_ca | indent(2, true) }}

imageDigestSources:
  - source: quay.io/openshift-release-dev/ocp-release
    mirrors:
      - {{ _registry_url }}/openshift/release-images
  - source: quay.io/openshift-release-dev/ocp-v4.0-art-dev
    mirrors:
      - {{ _registry_url }}/openshift/release
